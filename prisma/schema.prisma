// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// TABELA DE USUÁRIOS ADMIN
// ============================================
model User {
  id        String   @id @db.Uuid
  email     String   @unique
  role      String   @default("admin")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ============================================
// TABELA DE APLICAÇÕES (FORMULÁRIO PÚBLICO)
// ============================================
model Application {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Step 0: Aceitação + Motivação
  step0Accepted     Boolean @map("step0_accepted")
  missionMotivation String  @map("mission_motivation") @db.Text

  // Step 1: 4 Outcomes como JSONB
  // [{accepted: bool, comment: string}, ...]
  outcomes Json @db.JsonB

  // Step 2: 4 Competências como JSONB
  // [{name: string, rating: string, example: string}]
  competencies Json @db.JsonB

  // Step 3: Dados Pessoais
  fullName          String  @map("full_name")
  cpf               String
  birthDate         String  @map("birth_date")
  city              String
  state             String

  // Contato
  email    String
  whatsapp String

  // Profissional
  githubLink        String? @map("github_link")
  salaryExpectation String  @map("salary_expectation")
  availability      String
  finalNotes        String? @map("final_notes") @db.Text

  // Arquivos
  documents String[] @default([])

  // Metadados
  status    String   @default("pending")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("applications")
}
